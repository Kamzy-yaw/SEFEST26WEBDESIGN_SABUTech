FIREBASE_SERVICE_ACCOUNT_KEY=

# Alternative if you do not use FIREBASE_SERVICE_ACCOUNT_KEY:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
